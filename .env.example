# Search feature (Phase 2) — Nominatim geocoding provider configuration.
# Nominatim is keyless; these vars only tune the endpoint and outbound request
# behavior. See docs/environment-variables.md for full details.

# Base URL of the Nominatim-compatible geocoding service. Defaults to the
# public OpenStreetMap instance if unset.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Required by Nominatim's usage policy: a custom, application-identifying
# User-Agent sent on every outbound request. Set this to your own
# deployment's contact info before going to production.
SEARCH_USER_AGENT=SpatialMindAI/1.0 (contact: support@spatialmind.ai)

# Maximum outbound requests per second to the geocoding provider, enforced by
# the local rate limiter (Route Handlers). Defaults to 1, matching Nominatim's
# usage policy.
SEARCH_RATE_LIMIT_PER_SECOND=1
